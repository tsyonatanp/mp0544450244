# Google Places API — pulls the live Google rating & review count into the site/Schema.
# Get a key at https://console.cloud.google.com (enable "Places API (New)").
# Copy this file to .env.local and fill in the value. Do NOT commit .env.local.
GOOGLE_PLACES_API_KEY=

# Optional — defaults to the firm's Google place ID if left empty.
GOOGLE_PLACE_ID=ChIJOelfqmE1HRUR7tok_QKTy_A

# Telegram visit notifications — get a notification when someone visits the site.
# 1) Create a bot with @BotFather on Telegram → copy the token here.
# 2) Send your bot a message, then get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
